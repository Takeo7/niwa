# Caddy reverse proxy for the Niwa MCP gateway.
# Validates Authorization: Bearer <NIWA_REMOTE_TOKEN> on every request.
# Uses the compose service name `mcp-gateway` (resolvable inside the docker
# network) instead of a hardcoded container name, so it works regardless of
# the install's INSTANCE_NAME prefix.

{
	admin off
	auto_https off
}

:8443 {
	# Health endpoint (no auth)
	@health path /health
	handle @health {
		respond "ok" 200
	}

	# Authed MCP endpoint
	@authed header Authorization "Bearer {$NIWA_REMOTE_TOKEN}"
	handle @authed {
		reverse_proxy http://mcp-gateway:8811 {
			# MCP uses streamable HTTP / SSE — disable buffering
			flush_interval -1
			transport http {
				read_buffer 8192
				write_buffer 8192
			}
		}
	}

	# Reject everything else
	respond "Unauthorized" 401 {
		close
	}

	log {
		output stdout
		format json
	}
}
