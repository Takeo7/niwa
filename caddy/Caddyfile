# Caddy reverse proxy for the Niwa MCP gateway.
# Validates Authorization: Bearer <NIWA_REMOTE_TOKEN> on every request.
# The local gateway at niwa-mcp-gateway:8811 has auth disabled (container mode
# limitation of docker/mcp-gateway), so this is the only enforcement point.

{
	admin off
	auto_https off
}

:8443 {
	# Health endpoint (no auth)
	@health path /health
	handle @health {
		respond "ok" 200
	}

	# Authed MCP endpoint
	@authed header Authorization "Bearer {$NIWA_REMOTE_TOKEN}"
	handle @authed {
		reverse_proxy http://niwa-mcp-gateway:8811 {
			# MCP uses streamable HTTP / SSE — disable buffering
			flush_interval -1
			transport http {
				read_buffer 8192
				write_buffer 8192
			}
		}
	}

	# Reject everything else
	respond "Unauthorized" 401 {
		close
	}

	log {
		output stdout
		format json
	}
}
