# Desk — required environment variables
# Copy this file to .env and fill in all values before starting the server.

# --- Required (server will refuse to start without these) ---

# Password for Desk login
DESK_PASSWORD=

# Secret used to sign session cookies (use a long random string)
DESK_SESSION_SECRET=

# Auth tokens for the Claude bridge
CLAUDE_BRIDGE_AUTH=
CLAUDE_BRIDGE_TOKEN=

# --- Optional (have sensible defaults) ---

# DESK_USERNAME=arturo
# DESK_HOST=0.0.0.0
# DESK_PORT=8080
# DESK_AUTH_REQUIRED=1
# DESK_SESSION_TTL_HOURS=168
# DESK_LOGIN_ATTEMPTS=5
# DESK_LOGIN_WINDOW_SECONDS=900
# DESK_DB_PATH=data/desk.sqlite3
# DESK_PUBLIC_BASE_URL=http://127.0.0.1:8080
# DESK_COOKIE_DOMAIN=.yumewagener.com

# Claude bridge endpoint
# CLAUDE_BRIDGE_URL=http://172.17.0.1:18800/run

# Briefing ingestion token (POST /api/briefings returns 503 if unset)
# DESK_BRIEFING_TOKEN=

# Webhook integration
# DESK_WEBHOOK_TOKEN=
# YUME_WEBHOOK_URL=
# YUME_WEBHOOK_SECRET=

# OAuth (Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth (Microsoft)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Paths
# DESK_PROJECTS_DIR=/home/yume/projects
# DESK_ATTACHMENTS_DIR=attachments
# OPENCLAW_HOME=/home/yume/.openclaw
