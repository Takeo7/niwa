# Niwa install env — generated by `niwa install` from your wizard answers.
# This file is committed as an example only. Real install lives at
# ${NIWA_SECRETS_DIR}/mcp.env (chmod 600) and is gitignored.

# ── Identity ──
INSTANCE_NAME=niwa
NIWA_VERSION=0.1.0
NIWA_HOME=/Users/foo/.niwa

# ── Paths (derived from NIWA_HOME by default) ──
NIWA_LOGS_DIR=/Users/foo/.niwa/logs
NIWA_SECRETS_DIR=/Users/foo/.niwa/secrets
NIWA_DB_PATH=/Users/foo/.niwa/data/niwa.sqlite3
NIWA_FILESYSTEM_WORKSPACE=/Users/foo/.niwa/data
NIWA_FILESYSTEM_MEMORY=/Users/foo/.niwa/memory

# ── Ports (loopback only by default) ──
NIWA_GATEWAY_STREAMING_PORT=18810
NIWA_GATEWAY_SSE_PORT=18812
NIWA_CADDY_PORT=18811

# ── Enabled servers (subset of: tasks,notes,platform,filesystem) ──
NIWA_ENABLED_SERVERS=tasks,notes,platform,filesystem

# ── Server names (renameable in the wizard) ──
NIWA_TASKS_SERVER_NAME=tasks
NIWA_NOTES_SERVER_NAME=notes
NIWA_PLATFORM_SERVER_NAME=platform
NIWA_FILESYSTEM_SERVER_NAME=filesystem

# ── Tokens (auto-generated by setup.py) ──
MCP_GATEWAY_AUTH_TOKEN=
NIWA_LOCAL_TOKEN=
NIWA_REMOTE_TOKEN=

# ── Platform restart whitelist (comma-separated, NEVER include niwa stack containers) ──
PLATFORM_RESTART_WHITELIST=

# ── Public exposure (only if mode != local-only) ──
NIWA_MODE=local-only
NIWA_PUBLIC_DOMAIN=
NIWA_CLOUDFLARE_TUNNEL_ID=

# ── Detected integrations ──
NIWA_HAS_OPENCLAW=false
NIWA_HAS_CLAUDE_CODE=false
NIWA_HAS_CLOUDFLARED=false
