# Example of the env file generated by `niwa install` at:
#   ${NIWA_HOME}/secrets/mcp.env  (chmod 600)
#
# This file is committed for documentation only — do NOT edit and commit
# real values. The wizard generates a real one with your actual paths/tokens.

# ── Identity ──
INSTANCE_NAME=niwa
NIWA_VERSION=0.1.0
NIWA_HOME=/Users/foo/.niwa
DOCKER_SOCKET_PATH=/var/run/docker.sock

# ── Paths (derived from NIWA_HOME by default) ──
NIWA_LOGS_DIR=/Users/foo/.niwa/logs
NIWA_SECRETS_DIR=/Users/foo/.niwa/secrets
NIWA_DB_PATH=/Users/foo/.niwa/data/niwa.sqlite3
NIWA_FILESYSTEM_WORKSPACE=/Users/foo/.niwa/data
NIWA_FILESYSTEM_MEMORY=/Users/foo/.niwa/memory

# ── Networking ──
NIWA_BIND_HOST=127.0.0.1
NIWA_DATA_DIR=/Users/foo/.niwa/data

# ── Ports (loopback only by default) ──
NIWA_GATEWAY_STREAMING_PORT=18810
NIWA_GATEWAY_SSE_PORT=18812
NIWA_CADDY_PORT=18811
NIWA_APP_PORT=8080
NIWA_TERMINAL_PORT=7681

# ── Enabled servers (subset of: tasks,notes,platform,filesystem) ──
NIWA_ENABLED_SERVERS=tasks,notes,platform,filesystem

# ── Server names (renameable in the wizard) ──
NIWA_TASKS_SERVER_NAME=tasks
NIWA_NOTES_SERVER_NAME=notes
NIWA_PLATFORM_SERVER_NAME=platform
NIWA_FILESYSTEM_SERVER_NAME=filesystem

# ── Tokens (auto-generated by setup.py) ──
MCP_GATEWAY_AUTH_TOKEN=
NIWA_LOCAL_TOKEN=
NIWA_REMOTE_TOKEN=

# ── Platform restart whitelist (comma-separated container names) ──
PLATFORM_RESTART_WHITELIST=

# ── Niwa app web UI credentials ──
NIWA_APP_USERNAME=arturo
NIWA_APP_PASSWORD=
NIWA_APP_SESSION_SECRET=
NIWA_APP_PUBLIC_BASE_URL=http://localhost:8080
NIWA_APP_AUTH_REQUIRED=1

# ── Security: IPs de proxy confiables para X-Forwarded-For (separadas por coma) ──
# NIWA_TRUSTED_PROXIES=172.18.0.0/16,127.0.0.1

# ── Public exposure (only if mode != local-only) ──
NIWA_MODE=local-only
NIWA_PUBLIC_DOMAIN=
NIWA_CLOUDFLARE_TUNNEL_ID=

# ── Detected integrations (set by wizard) ──
NIWA_REGISTERED_CLAUDE=0
NIWA_REGISTERED_OPENCLAW=0

# ── Task executor (host-side worker) ──
NIWA_EXECUTOR_ENABLED=0
NIWA_LLM_PROVIDER=
NIWA_LLM_COMMAND=
NIWA_LLM_API_KEY=
# Defaults if executor enabled:
NIWA_EXECUTOR_POLL_SECONDS=30
NIWA_EXECUTOR_TIMEOUT_SECONDS=1800
NIWA_EXECUTOR_MAX_OUTPUT=10000

# ── Notifications (optional, used by routines scheduler) ──
NIWA_TELEGRAM_BOT_TOKEN=
NIWA_TELEGRAM_CHAT_ID=
NIWA_WEBHOOK_URL=
