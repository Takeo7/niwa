# Niwa MCP stack — template (parameterized)
# Generated docker-compose.yml is produced by `niwa install` by substituting
# dollar-brace placeholders from niwa.env. Do NOT edit the generated file directly — re-run install.
#
# Variables expected (set by setup.py):
#   INSTANCE_NAME                    e.g. "niwa" — prefix for container names
#   NIWA_HOME                        e.g. ~/.niwa — install root
#   NIWA_LOGS_DIR                    e.g. $NIWA_HOME/logs
#   NIWA_SECRETS_DIR                 e.g. $NIWA_HOME/secrets
#   NIWA_DB_PATH                     e.g. $NIWA_HOME/data/niwa.sqlite3
#   NIWA_GATEWAY_STREAMING_PORT      e.g. 18810 — host port for streamable HTTP gateway
#   NIWA_GATEWAY_SSE_PORT            e.g. 18812 — host port for SSE gateway
#   NIWA_CADDY_PORT                  e.g. 18811 — host port for Caddy reverse proxy
#   NIWA_APP_PORT                    e.g. 8080  — host port for the Niwa web app
#   DOCKER_SOCKET_PATH               e.g. /var/run/docker.sock — detected by wizard
#   PLATFORM_RESTART_WHITELIST       e.g. "my-app,arturo-cron" — comma-separated
#                                    (read by platform-mcp at spawn time, not by compose)
#   NIWA_ENABLED_SERVERS             e.g. "tasks,notes,platform,filesystem" — passed via --servers

services:
  socket-proxy:
    image: tecnativa/docker-socket-proxy:latest
    container_name: ${INSTANCE_NAME}-socket-proxy
    restart: unless-stopped
    environment:
      CONTAINERS: 1
      IMAGES: 1
      NETWORKS: 1
      VOLUMES: 1
      EXEC: 1
      POST: 1
      INFO: 1
      VERSION: 1
    volumes:
      - ${DOCKER_SOCKET_PATH}:/var/run/docker.sock:ro
    networks:
      - niwa-net
    mem_limit: 64m
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "2"

  mcp-gateway:
    image: docker/mcp-gateway:latest
    container_name: ${INSTANCE_NAME}-mcp-gateway
    restart: unless-stopped
    depends_on:
      - socket-proxy
    environment:
      DOCKER_HOST: tcp://socket-proxy:2375
    env_file:
      - ${NIWA_SECRETS_DIR}/mcp.env
    command:
      - --transport=streaming
      - --port=8811
      - --catalog=/config/niwa-catalog.yaml
      - --config=/config/niwa-config.yaml
      - --secrets=/secrets/mcp.env
      - --servers=${NIWA_ENABLED_SERVERS}
      - --log-calls
      - --verbose
    volumes:
      - ${NIWA_HOME}/config:/config:ro
      - ${NIWA_SECRETS_DIR}:/secrets:ro
      - ${NIWA_LOGS_DIR}:/logs:rw
    ports:
      - "127.0.0.1:${NIWA_GATEWAY_STREAMING_PORT}:8811"
    networks:
      - niwa-net
    mem_limit: 256m
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "3"

  mcp-gateway-sse:
    # Twin gateway in legacy SSE transport mode for clients that don't speak
    # streamable HTTP (e.g. OpenClaw's bundled MCP client). Same catalog,
    # same backing servers, different transport.
    image: docker/mcp-gateway:latest
    container_name: ${INSTANCE_NAME}-mcp-gateway-sse
    restart: unless-stopped
    depends_on:
      - socket-proxy
    environment:
      DOCKER_HOST: tcp://socket-proxy:2375
    env_file:
      - ${NIWA_SECRETS_DIR}/mcp.env
    command:
      - --transport=sse
      - --port=8811
      - --catalog=/config/niwa-catalog.yaml
      - --config=/config/niwa-config.yaml
      - --secrets=/secrets/mcp.env
      - --servers=${NIWA_ENABLED_SERVERS}
      - --log-calls
      - --verbose
    volumes:
      - ${NIWA_HOME}/config:/config:ro
      - ${NIWA_SECRETS_DIR}:/secrets:ro
      - ${NIWA_LOGS_DIR}:/logs:rw
    ports:
      - "127.0.0.1:${NIWA_GATEWAY_SSE_PORT}:8811"
    networks:
      - niwa-net
    mem_limit: 256m
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "3"

  app:
    # Niwa app — web UI for tasks/projects/notes/system
    image: ${INSTANCE_NAME}-app:latest
    container_name: ${INSTANCE_NAME}-app
    restart: unless-stopped
    env_file:
      - ${NIWA_SECRETS_DIR}/mcp.env
    environment:
      NIWA_DB_PATH: /data/niwa.sqlite3
      NIWA_APP_HOST: 0.0.0.0
      NIWA_APP_PORT: "8080"
    volumes:
      - ${NIWA_DB_PATH}:/data/niwa.sqlite3
    ports:
      - "127.0.0.1:${NIWA_APP_PORT}:8080"
    networks:
      - niwa-net
    mem_limit: 256m
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "3"

  caddy:
    image: caddy:2-alpine
    container_name: ${INSTANCE_NAME}-caddy
    restart: unless-stopped
    depends_on:
      - mcp-gateway
    env_file:
      - ${NIWA_SECRETS_DIR}/mcp.env
    volumes:
      - ${NIWA_HOME}/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
    ports:
      - "127.0.0.1:${NIWA_CADDY_PORT}:8443"
    networks:
      - niwa-net
    mem_limit: 64m
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "2"

  terminal:
    # Web terminal — provides a real host shell via the browser.
    # Uses chroot /host to access the host filesystem from inside the container.
    # Protected with the same Niwa username/password (basic auth).
    image: tsl0922/ttyd:latest
    container_name: ${INSTANCE_NAME}-terminal
    restart: unless-stopped
    command: >-
      ttyd -W -p 7681
      -c ${NIWA_APP_USERNAME}:${NIWA_APP_PASSWORD}
      chroot /host bash -l
    pid: host
    privileged: true
    network_mode: host
    volumes:
      - /:/host
    ports:
      - "127.0.0.1:${NIWA_TERMINAL_PORT}:7681"
    mem_limit: 128m
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "1"

networks:
  niwa-net:
    driver: bridge
    name: ${INSTANCE_NAME}-net
